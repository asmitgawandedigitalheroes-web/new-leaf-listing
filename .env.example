# =============================================================================
# NLVListings — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (required)
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://<your-project>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-key>

# -----------------------------------------------------------------------------
# Stripe keys must be set in Supabase Edge Function Secrets, NOT here.
# Go to: Supabase Dashboard → Settings → Edge Functions → Secrets
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_STARTER_PRICE_ID=price_...
# STRIPE_PRO_PRICE_ID=price_...
# STRIPE_DOMINATOR_PRICE_ID=price_...
# STRIPE_SPONSOR_PRICE_ID=price_...
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# GoHighLevel CRM (v2 LeadConnector API)
# -----------------------------------------------------------------------------
# PIT token from GHL → Settings → Private Integrations
VITE_GHL_API_KEY=
# Sub-account Location ID (GHL → Settings → Business Profile → Location ID)
VITE_GHL_LOCATION_ID=
# Agency API key — only needed for sub-account creation (createSubAccount.ts)
VITE_GHL_AGENCY_API_KEY=
# Pipeline ID for opportunity stage syncing (GHL → Pipelines → copy ID from URL)
VITE_GHL_PIPELINE_ID=
# Workflow ID for automated follow-up (GHL → Automation → Workflows → copy ID)
VITE_GHL_FOLLOWUP_WORKFLOW_ID=
# HMAC secret for inbound webhook signature validation
VITE_GHL_WEBHOOK_SECRET=
# GHL API base (do not change unless using a self-hosted LC instance)
VITE_GHL_BASE_URL=https://services.leadconnectorhq.com

# Legacy webhook URL (optional — only if using GHL workflow webhooks instead of direct API)
VITE_GHL_WEBHOOK_URL=

# Other CRM providers (optional)
VITE_SALESPRO_WEBHOOK_URL=https://...
VITE_SALESPRO_API_KEY=<your-salespro-api-key>
VITE_LEAP_WEBHOOK_URL=https://...
VITE_LEAP_API_KEY=<your-leap-api-key>

# -----------------------------------------------------------------------------
# Demo credentials — DEVELOPMENT ONLY (import.meta.env.DEV must be true)
# These are never bundled into production builds.
# -----------------------------------------------------------------------------
VITE_DEMO_ADMIN_EMAIL=admin@nlvlistings.com
VITE_DEMO_ADMIN_PASS=admin123
VITE_DEMO_DIRECTOR_EMAIL=director@nlvlistings.com
VITE_DEMO_DIRECTOR_PASS=director123
VITE_DEMO_REALTOR_EMAIL=realtor@nlvlistings.com
VITE_DEMO_REALTOR_PASS=realtor123

# Toggle Mock CRM mode (true = log to console, false = call actual webhooks)
VITE_USE_MOCK_CRM=true

# -----------------------------------------------------------------------------
# App URL (used for invite links, email redirects, referral links)
# Set this to your deployed domain in production.
# -----------------------------------------------------------------------------
VITE_APP_URL=https://your-domain.com
